name=os-test
version=ec05ef048b20caf61afe5b7c0ff5212c6dd2a505
revision=1
git_url="https://gitlab.com/sortix/os-test.git"
commit=${version}
imagedeps="build-essential"
hostdeps="gcc binutils"
deps="core-libs"

configure() {
	cp -rpa ${source_dir}/* .
}

build() {
	make -j${parallelism} OS=Zinnia CC=${TARGET_CC} CC_FOR_BUILD=gcc
}

package() {
	mkdir -pv "${dest_dir}/usr/share/os-test"
	cp -rpa * "${dest_dir}/usr/share/os-test"
}
