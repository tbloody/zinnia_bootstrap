+    }
+    pub const fn WIFSIGNALED(status: c_int) -> bool {
+        ((((status & 0x7f) + 1) as i8) >> 1) > 0
+    }
+    pub const fn WIFSTOPPED(status: c_int) -> bool {
+        (status & 0xff) == 0x7f
+    }
