+        (status >> 8) & 0xff
+    }
+    pub const fn WIFCONTINUED(status: c_int) -> bool {
+        status == 0xffff
+    }
+    pub const fn WCOREDUMP(status: c_int) -> bool {
+        (status & 0x80) != 0
